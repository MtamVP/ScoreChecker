{
  "manifest_version": 3,
  "name": "ScoreChecker (ĐGNL)",
  "version": "1.0.0",
  "description": "Tra cứu điểm thi Đánh Giá Năng Lực ĐHQG TP.HCM nhanh chóng.",
  "permissions": [
    "cookies",
    "alarms",
    "notifications",
    "storage",
    "tabs",
    "scripting"
  ],
  "host_permissions": [
    "https://thinangluc.vnuhcm.edu.vn/*",
    "https://discord.com/*"
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://thinangluc.vnuhcm.edu.vn/*"
      ],
      "js": [
        "content/auto-login.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
